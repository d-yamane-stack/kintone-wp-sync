# =============================
# KINTONE設定
# =============================
KINTONE_SUBDOMAIN=housing-jube
KINTONE_APP_ID=207
KINTONE_API_TOKEN=ここにKINTONEのAPIトークンを入力

# =============================
# Claude API設定
# =============================
ANTHROPIC_API_KEY=ここにAnthropicのAPIキーを入力

# =============================
# WordPress設定
# =============================
WP_BASE_URL=https://jube.co.jp/refresh2022
WP_POST_TYPE=example
WP_USERNAME=WordPressのユーザー名
WP_APP_PASSWORD=WordPressのアプリケーションパスワード（生成後に入力）

# =============================
# Google Apps Script設定
# =============================
GAS_WEBHOOK_URL=GASデプロイ後のWebhook URLを入力
